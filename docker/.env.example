# docker/.env.example — Environment variable template for Docker stack
#
# Copy to .env and fill in real values before running docker-compose:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — required for Investigation, Monitoring, and Policy agents
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Athena database name (for industry benchmarks — dev uses local fallback)
# ATHENA_DATABASE=compliance_db

# Athena S3 results bucket
# ATHENA_S3_BUCKET=s3://your-bucket/athena-results/

# AWS region for Athena queries
# AWS_DEFAULT_REGION=us-east-1
