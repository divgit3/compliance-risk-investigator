# ── AI / LLM ─────────────────────────────────────────────────────────────────
# OpenAI API key — used by LangChain and direct openai SDK calls
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Vector Database (Qdrant) ─────────────────────────────────────────────────
# Qdrant runs locally via Docker; these defaults match docker-compose.yml
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Experiment Tracking (MLflow) ─────────────────────────────────────────────
# MLflow UI runs locally via Docker; this URI points to the tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# ── AWS (used in later phases for S3, Athena, Glue, ECS) ────────────────────
# Leave blank for local development; fill in when deploying to AWS
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=compliance-risk-investigator

# ── Project Configuration ─────────────────────────────────────────────────────
# TARGET_COMPANY filters which pharma company is the subject of investigation
# ENVIRONMENT controls logging verbosity and feature flags
TARGET_COMPANY=NovaPharma Inc
ENVIRONMENT=development
GLUE_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/AWSGlueServiceRole

