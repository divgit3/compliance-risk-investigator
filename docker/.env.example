# docker/.env.example — Environment variable template for Docker stack
#
# Copy to .env and fill in real values before running docker-compose:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — required for Investigation, Monitoring, and Policy agents
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Athena database name — Glue Catalog database where compliance tables live
# ATHENA_DATABASE=compliance_risk_raw

# Athena S3 query result location — where Athena writes query result CSVs
# (separate from dbt-materialized table storage at athena-results/tables/)
# ATHENA_S3_BUCKET=s3://your-bucket/athena-query-output/

# Athena S3 staging directory for pyathena library — same purpose as ATHENA_S3_BUCKET
# but read by features/hcp_spend_features.py
# ATHENA_S3_STAGING_DIR=s3://your-bucket/athena-query-output/

# AWS region — must match where your Glue catalog and S3 bucket exist
# Both AWS_REGION and AWS_DEFAULT_REGION are needed (different SDKs read different vars)
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
