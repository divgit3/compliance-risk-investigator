# ── AI / LLM ─────────────────────────────────────────────────────────────────
# OpenAI API key — used by LangChain and direct openai SDK calls
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Vector Database (Qdrant) ─────────────────────────────────────────────────
# Qdrant runs locally via Docker; these defaults match docker-compose.yml
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Experiment Tracking (MLflow) ─────────────────────────────────────────────
# MLflow UI runs locally via Docker; this URI points to the tracking server
# NOTE: Port 5001 is used because macOS AirPlay/Control Center occupies 5000
MLFLOW_TRACKING_URI=http://localhost:5001
# MLFLOW_ENABLED=true   # set to false to disable MLflow logging (useful if tracking server unavailable)

# ── AWS (used for S3, Athena, Glue) ─────────────────────────────────────────
# Required for feature pipelines and dbt (Athena-backed models)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1   # boto3 reads AWS_DEFAULT_REGION; set both to avoid SDK-specific drift
S3_BUCKET_NAME=your-s3-bucket-name
GLUE_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/AWSGlueServiceRole

# ── Athena ────────────────────────────────────────────────────────────────────
# ATHENA_DATABASE=compliance_risk_raw        # Glue Catalog database name
# ATHENA_S3_BUCKET=s3://your-s3-bucket-name/athena-query-output/
# ATHENA_S3_STAGING_DIR=s3://your-s3-bucket-name/athena-query-output/

